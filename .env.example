# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Stripe configurations (optional, falls back to simulation mode)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# AWS S3 file storage configurations (optional, falls back to memory storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# Google Gemini API Config
GOOGLE_GEMINI_API_KEY=

# Google OAuth Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Convex Deployment Config
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Admin UI access password (defaults to "admin123" if empty)
ADMIN_PASSWORD=admin123
